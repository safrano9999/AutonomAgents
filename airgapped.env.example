# Optional defaults for airgapped.sh.
# Copy to ./airgapped.env or pass with AIRGAPPED_CONFIG=/path/to/file.

# MODE can still be supplied by --save, --load, or --patch.
# MODE=save

# Required for --save unless passed with --arch.
ARCH=linux/arm64

# Pin component versions. A leading "v" is accepted and normalized.
# OPENCLAW_VERSION=2026.4.24
# HERMES_VERSION=0.1.0

# Optional engine defaults.
# SAVE_ENGINE=podman
# LOAD_ENGINE=podman
